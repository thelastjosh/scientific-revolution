# Copy to .env and fill in values (never commit .env).

# Supabase Postgres — use the pooled connection string for serverless / short-lived Node.
# Dashboard: Project Settings → Database → Connection string (URI).
# POSTGRES_URL is the canonical DB variable used by runtime and migrations.
POSTGRES_URL=
# Optional: keep this unset, or set equal to POSTGRES_URL only.
# DATABASE_URL=

# If your DB host is not auto-detected (Supabase/Neon/Vercel), set to relax TLS for Node/pg:
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Canonical site URL for Open Graph / Twitter meta tags (include https://).
# On Vercel you can omit if VERCEL_URL is enough; set this for a custom domain.
SITE_URL=

# Local dev / Node host only (ignored on Vercel static deploys).
# On many Macs, AirPlay Receiver (Control Center) already uses 5000 — if `npm run dev`
# fails with EADDRINUSE, set PORT=5001 (or turn off AirPlay Receiver in System Settings).
PORT=5000

# Anthropic — onboarding chat on the home page (server-side only).
# ANTHROPIC_API_KEY=
# Optional model override (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=

# Onboarding system prompt A/B: control | variant_b (see server/prompts/onboarding/)
# ONBOARDING_SYSTEM_PROMPT_VARIANT=control

# Admin UI (/admin): required to PUT experiment toggles. Use a long random string.
# ADMIN_SECRET=

# JWT session cookie signing (required in production; min 16 chars). Dev falls back to an insecure key.
# SESSION_SECRET=

# Future: Supabase client (browser) — anon key, project URL
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=